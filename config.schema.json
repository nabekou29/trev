{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "description": "Application configuration.",
  "type": "object",
  "properties": {
    "display": {
      "description": "Display settings.",
      "$ref": "#/$defs/DisplayConfig",
      "default": {
        "column_options": {
          "modified_at": {
            "format": "relative",
            "mode": "os_mtime"
          }
        },
        "columns": [
          "git_status",
          "size",
          "modified_at"
        ],
        "file_styles": [],
        "show_hidden": false,
        "show_icons": true,
        "show_ignored": false,
        "show_preview": true,
        "show_root_entry": false,
        "styles": {
          "directory": {
            "bg": null,
            "bold": true,
            "crossed_out": false,
            "dim": false,
            "fg": "blue",
            "italic": false,
            "underlined": false
          },
          "git_status": {
            "added": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "green",
              "italic": false,
              "underlined": false
            },
            "conflicted": {
              "bg": null,
              "bold": true,
              "crossed_out": false,
              "dim": false,
              "fg": "red",
              "italic": false,
              "underlined": false
            },
            "deleted": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "red",
              "italic": false,
              "underlined": false
            },
            "modified": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "yellow",
              "italic": false,
              "underlined": false
            },
            "renamed": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "blue",
              "italic": false,
              "underlined": false
            },
            "staged": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "green",
              "italic": false,
              "underlined": false
            },
            "staged_modified": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "yellow",
              "italic": false,
              "underlined": false
            },
            "untracked": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "magenta",
              "italic": false,
              "underlined": false
            }
          },
          "gitignored": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "dark_gray",
            "italic": false,
            "underlined": false
          },
          "symlink": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "cyan",
            "italic": false,
            "underlined": false
          }
        }
      }
    },
    "file_op": {
      "description": "File operation settings.",
      "$ref": "#/$defs/FileOpConfig",
      "default": {
        "delete_mode": "permanent",
        "undo_stack_size": 100
      }
    },
    "git": {
      "description": "Git integration settings.",
      "$ref": "#/$defs/GitConfig",
      "default": {
        "enabled": true
      }
    },
    "keybindings": {
      "description": "Keybinding customization.",
      "$ref": "#/$defs/KeybindingConfig",
      "default": {
        "daemon": {
          "directory": {
            "bindings": [],
            "disable_default": false
          },
          "file": {
            "bindings": [],
            "disable_default": false
          },
          "universal": {
            "bindings": [],
            "disable_default": false
          }
        },
        "directory": {
          "bindings": [],
          "disable_default": false
        },
        "disable_default": false,
        "file": {
          "bindings": [],
          "disable_default": false
        },
        "key_sequence_timeout_ms": 500,
        "universal": {
          "bindings": [],
          "disable_default": false
        }
      }
    },
    "menus": {
      "description": "User-defined menus.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/MenuDefinition"
      },
      "default": {}
    },
    "mouse": {
      "description": "Mouse settings.",
      "$ref": "#/$defs/MouseConfig",
      "default": {
        "enabled": true
      }
    },
    "preview": {
      "description": "Preview settings.",
      "$ref": "#/$defs/PreviewConfig",
      "default": {
        "cache_size": 50,
        "command_timeout": 3,
        "commands": [],
        "max_bytes": 10485760,
        "max_lines": 1000,
        "narrow_split_ratio": 60,
        "narrow_width": 80,
        "split_ratio": 50,
        "word_wrap": false
      }
    },
    "search": {
      "description": "Search settings.",
      "$ref": "#/$defs/SearchConfig",
      "default": {}
    },
    "session": {
      "description": "Session persistence settings.",
      "$ref": "#/$defs/SessionConfig",
      "default": {
        "expiry_days": 90,
        "restore_by_default": true
      }
    },
    "sort": {
      "description": "Sort settings.",
      "$ref": "#/$defs/SortConfig",
      "default": {
        "direction": "asc",
        "directories_first": true,
        "order": "smart"
      }
    },
    "watcher": {
      "description": "File system watcher settings.",
      "$ref": "#/$defs/WatcherConfig",
      "default": {
        "debounce_ms": 250,
        "enabled": true
      }
    }
  },
  "$defs": {
    "CategoryStyles": {
      "description": "Category-based default display styles.",
      "type": "object",
      "properties": {
        "directory": {
          "description": "Style for directory names.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": true,
            "crossed_out": false,
            "dim": false,
            "fg": "blue",
            "italic": false,
            "underlined": false
          }
        },
        "git_status": {
          "description": "Per-status styles for git-tracked files.",
          "$ref": "#/$defs/GitStatusStyles",
          "default": {
            "added": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "green",
              "italic": false,
              "underlined": false
            },
            "conflicted": {
              "bg": null,
              "bold": true,
              "crossed_out": false,
              "dim": false,
              "fg": "red",
              "italic": false,
              "underlined": false
            },
            "deleted": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "red",
              "italic": false,
              "underlined": false
            },
            "modified": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "yellow",
              "italic": false,
              "underlined": false
            },
            "renamed": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "blue",
              "italic": false,
              "underlined": false
            },
            "staged": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "green",
              "italic": false,
              "underlined": false
            },
            "staged_modified": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "yellow",
              "italic": false,
              "underlined": false
            },
            "untracked": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "magenta",
              "italic": false,
              "underlined": false
            }
          }
        },
        "gitignored": {
          "description": "Style for gitignored file names.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "dark_gray",
            "italic": false,
            "underlined": false
          }
        },
        "symlink": {
          "description": "Style for symbolic link names.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "cyan",
            "italic": false,
            "underlined": false
          }
        }
      }
    },
    "ColorConfig": {
      "description": "A color: named (red, blue, cyan, dark_gray, …) or hex (#RRGGBB)",
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "black",
            "red",
            "green",
            "yellow",
            "blue",
            "magenta",
            "cyan",
            "gray",
            "dark_gray",
            "light_red",
            "light_green",
            "light_yellow",
            "light_blue",
            "light_magenta",
            "light_cyan",
            "white"
          ]
        },
        {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        }
      ]
    },
    "ColumnKind": {
      "description": "Kind of column that can be displayed in the tree view.",
      "oneOf": [
        {
          "description": "File size (human-readable).",
          "type": "string",
          "const": "size"
        },
        {
          "description": "Last modification time.",
          "type": "string",
          "const": "modified_at"
        },
        {
          "description": "Git status indicator.",
          "type": "string",
          "const": "git_status"
        }
      ]
    },
    "ColumnOptionsConfig": {
      "description": "Per-column options configuration.\n\nEach field corresponds to a column kind that supports options.",
      "type": "object",
      "properties": {
        "modified_at": {
          "description": "Options for the `ModifiedAt` column.",
          "$ref": "#/$defs/ModifiedAtColumnOptions",
          "default": {
            "format": "relative",
            "mode": "os_mtime"
          }
        }
      }
    },
    "ContextBindings": {
      "description": "Keybindings for a specific context.",
      "type": "object",
      "properties": {
        "bindings": {
          "description": "Keybinding entries.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/KeyBindingEntry"
          }
        },
        "disable_default": {
          "description": "Disable default keybindings for this context.",
          "type": "boolean",
          "default": false
        }
      }
    },
    "DaemonBindings": {
      "description": "Daemon-mode keybindings, subdivided by node context.",
      "type": "object",
      "properties": {
        "directory": {
          "description": "Bindings active in daemon mode when cursor is on a directory.",
          "$ref": "#/$defs/ContextBindings",
          "default": {
            "bindings": [],
            "disable_default": false
          }
        },
        "file": {
          "description": "Bindings active in daemon mode when cursor is on a file.",
          "$ref": "#/$defs/ContextBindings",
          "default": {
            "bindings": [],
            "disable_default": false
          }
        },
        "universal": {
          "description": "Bindings active in daemon mode regardless of node type.",
          "$ref": "#/$defs/ContextBindings",
          "default": {
            "bindings": [],
            "disable_default": false
          }
        }
      }
    },
    "DeleteMode": {
      "description": "Delete mode variants.",
      "oneOf": [
        {
          "description": "Permanently delete files (undo not possible).",
          "type": "string",
          "const": "permanent"
        },
        {
          "description": "Move files to custom trash directory (undo possible).",
          "type": "string",
          "const": "custom_trash"
        }
      ]
    },
    "DisplayConfig": {
      "description": "Display configuration.",
      "type": "object",
      "properties": {
        "column_options": {
          "description": "Per-column options (e.g., format and mode for `modified_at`).",
          "$ref": "#/$defs/ColumnOptionsConfig",
          "default": {
            "modified_at": {
              "format": "relative",
              "mode": "os_mtime"
            }
          }
        },
        "columns": {
          "description": "Columns to display in the tree view (ordered list of column kinds).",
          "type": "array",
          "default": [
            "git_status",
            "size",
            "modified_at"
          ],
          "items": {
            "$ref": "#/$defs/ColumnKind"
          }
        },
        "file_styles": {
          "description": "Per-file style rules matched by glob pattern (applied in order; later rules win).",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/FileStyleRule"
          }
        },
        "show_hidden": {
          "description": "Show hidden files.",
          "type": "boolean",
          "default": false
        },
        "show_icons": {
          "description": "Show file icons (Nerd Fonts).",
          "type": "boolean",
          "default": true
        },
        "show_ignored": {
          "description": "Show gitignored files.",
          "type": "boolean",
          "default": false
        },
        "show_preview": {
          "description": "Show preview panel.",
          "type": "boolean",
          "default": true
        },
        "show_root_entry": {
          "description": "Show root directory as a tree node.",
          "type": "boolean",
          "default": false
        },
        "styles": {
          "description": "Category-based default styles (directory, symlink, gitignored, git status).",
          "$ref": "#/$defs/CategoryStyles",
          "default": {
            "directory": {
              "bg": null,
              "bold": true,
              "crossed_out": false,
              "dim": false,
              "fg": "blue",
              "italic": false,
              "underlined": false
            },
            "git_status": {
              "added": {
                "bg": null,
                "bold": false,
                "crossed_out": false,
                "dim": false,
                "fg": "green",
                "italic": false,
                "underlined": false
              },
              "conflicted": {
                "bg": null,
                "bold": true,
                "crossed_out": false,
                "dim": false,
                "fg": "red",
                "italic": false,
                "underlined": false
              },
              "deleted": {
                "bg": null,
                "bold": false,
                "crossed_out": false,
                "dim": false,
                "fg": "red",
                "italic": false,
                "underlined": false
              },
              "modified": {
                "bg": null,
                "bold": false,
                "crossed_out": false,
                "dim": false,
                "fg": "yellow",
                "italic": false,
                "underlined": false
              },
              "renamed": {
                "bg": null,
                "bold": false,
                "crossed_out": false,
                "dim": false,
                "fg": "blue",
                "italic": false,
                "underlined": false
              },
              "staged": {
                "bg": null,
                "bold": false,
                "crossed_out": false,
                "dim": false,
                "fg": "green",
                "italic": false,
                "underlined": false
              },
              "staged_modified": {
                "bg": null,
                "bold": false,
                "crossed_out": false,
                "dim": false,
                "fg": "yellow",
                "italic": false,
                "underlined": false
              },
              "untracked": {
                "bg": null,
                "bold": false,
                "crossed_out": false,
                "dim": false,
                "fg": "magenta",
                "italic": false,
                "underlined": false
              }
            },
            "gitignored": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "dark_gray",
              "italic": false,
              "underlined": false
            },
            "symlink": {
              "bg": null,
              "bold": false,
              "crossed_out": false,
              "dim": false,
              "fg": "cyan",
              "italic": false,
              "underlined": false
            }
          }
        }
      }
    },
    "ExternalCommand": {
      "description": "External command configuration for preview.",
      "type": "object",
      "properties": {
        "args": {
          "description": "Command arguments.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "command": {
          "description": "Command name (must be in `$PATH`).",
          "type": "string"
        },
        "directories": {
          "description": "Whether this command handles directories.",
          "type": "boolean",
          "default": false
        },
        "extensions": {
          "description": "File extensions this command applies to.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "git_status": {
          "description": "Git status condition: only apply when file has one of these statuses.\n\nValues: `modified`, `staged`, `added`, `deleted`, `renamed`, `untracked`, `conflicted`.\nEmpty means no git status filtering.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "name": {
          "description": "Display name for this command provider.\n\nDefaults to the command binary name when omitted.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "priority": {
          "description": "Priority for ordering (lower = higher priority, default: 100).\n\nAccepts a number or a named constant: `high` (0), `mid` (100), `low` (1000).",
          "$ref": "#/$defs/Priority",
          "default": 100
        }
      },
      "required": [
        "command"
      ]
    },
    "FileOpConfig": {
      "description": "File operation configuration.",
      "type": "object",
      "properties": {
        "delete_mode": {
          "description": "Delete mode for the `d` key.",
          "$ref": "#/$defs/DeleteMode",
          "default": "permanent"
        },
        "undo_stack_size": {
          "description": "Maximum undo stack size.",
          "type": "integer",
          "format": "uint",
          "default": 100,
          "minimum": 0
        }
      }
    },
    "FileStyleRule": {
      "type": "object",
      "properties": {
        "pattern": {
          "description": "A glob pattern or list of glob patterns",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "style": {
          "$ref": "#/$defs/StyleConfig"
        }
      },
      "required": [
        "pattern",
        "style"
      ]
    },
    "GitConfig": {
      "description": "Git integration configuration.",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Whether Git integration is enabled.",
          "type": "boolean",
          "default": true
        }
      }
    },
    "GitStatusStyles": {
      "description": "Per-git-status display styles.",
      "type": "object",
      "properties": {
        "added": {
          "description": "Style for newly added files.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "green",
            "italic": false,
            "underlined": false
          }
        },
        "conflicted": {
          "description": "Style for conflicted files.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": true,
            "crossed_out": false,
            "dim": false,
            "fg": "red",
            "italic": false,
            "underlined": false
          }
        },
        "deleted": {
          "description": "Style for deleted files.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "red",
            "italic": false,
            "underlined": false
          }
        },
        "modified": {
          "description": "Style for unstaged modifications.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "yellow",
            "italic": false,
            "underlined": false
          }
        },
        "renamed": {
          "description": "Style for renamed files.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "blue",
            "italic": false,
            "underlined": false
          }
        },
        "staged": {
          "description": "Style for staged-only changes.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "green",
            "italic": false,
            "underlined": false
          }
        },
        "staged_modified": {
          "description": "Style for staged changes with working tree modifications.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "yellow",
            "italic": false,
            "underlined": false
          }
        },
        "untracked": {
          "description": "Style for untracked files.",
          "$ref": "#/$defs/StyleConfig",
          "default": {
            "bg": null,
            "bold": false,
            "crossed_out": false,
            "dim": false,
            "fg": "magenta",
            "italic": false,
            "underlined": false
          }
        }
      }
    },
    "KeyBindingEntry": {
      "description": "A keybinding entry. Exactly one of 'action', 'run', 'notify', or 'menu' must be set.",
      "type": "object",
      "properties": {
        "action": {
          "description": "Built-in action name",
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "quit",
                "help",
                "noop",
                "tree.move_down",
                "tree.move_up",
                "tree.expand",
                "tree.collapse",
                "tree.toggle_expand",
                "tree.jump_first",
                "tree.jump_last",
                "tree.half_page_down",
                "tree.half_page_up",
                "tree.expand_all",
                "tree.collapse_all",
                "tree.refresh",
                "tree.change_root",
                "tree.change_root_up",
                "tree.center_cursor",
                "tree.scroll_cursor_to_top",
                "tree.scroll_cursor_to_bottom",
                "tree.sort.menu",
                "tree.sort.toggle_direction",
                "tree.sort.by_name",
                "tree.sort.by_size",
                "tree.sort.by_mtime",
                "tree.sort.by_type",
                "tree.sort.by_extension",
                "tree.sort.by_smart",
                "tree.sort.toggle_directories_first",
                "filter.hidden",
                "filter.ignored",
                "preview.scroll_down",
                "preview.scroll_up",
                "preview.scroll_right",
                "preview.scroll_left",
                "preview.half_page_down",
                "preview.half_page_up",
                "preview.cycle_next_provider",
                "preview.cycle_prev_provider",
                "preview.toggle_preview",
                "preview.toggle_wrap",
                "file_op.yank",
                "file_op.cut",
                "file_op.paste",
                "file_op.create_file",
                "file_op.create_directory",
                "file_op.rename",
                "file_op.delete",
                "file_op.system_trash",
                "file_op.undo",
                "file_op.redo",
                "file_op.toggle_mark",
                "file_op.clear_selections",
                "file_op.copy.menu",
                "file_op.copy.absolute_path",
                "file_op.copy.relative_path",
                "file_op.copy.file_name",
                "file_op.copy.stem",
                "file_op.copy.parent_dir",
                "search.open"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "background": {
          "description": "Run shell command in background without suspending TUI",
          "type": "boolean",
          "default": false
        },
        "key": {
          "description": "Key notation (e.g. \"j\", \"<C-a>\", \"G\", \"<CR>\")",
          "type": "string"
        },
        "menu": {
          "description": "User-defined menu name to open",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "notify": {
          "description": "IPC notification method name",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "run": {
          "description": "Shell command template. Variables: {path}, {dir}, {name}, {root}",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "key"
      ]
    },
    "KeybindingConfig": {
      "description": "Keybinding configuration with context-based sections.\n\nEach section groups bindings by context: `universal` (always active),\n`file` (cursor on file), `directory` (cursor on directory), and\n`daemon.*` (daemon mode variants).",
      "type": "object",
      "properties": {
        "daemon": {
          "description": "Bindings active in daemon mode.",
          "$ref": "#/$defs/DaemonBindings",
          "default": {
            "directory": {
              "bindings": [],
              "disable_default": false
            },
            "file": {
              "bindings": [],
              "disable_default": false
            },
            "universal": {
              "bindings": [],
              "disable_default": false
            }
          }
        },
        "directory": {
          "description": "Bindings active when cursor is on a directory.",
          "$ref": "#/$defs/ContextBindings",
          "default": {
            "bindings": [],
            "disable_default": false
          }
        },
        "disable_default": {
          "description": "Disable all default keybindings.",
          "type": "boolean",
          "default": false
        },
        "file": {
          "description": "Bindings active when cursor is on a file.",
          "$ref": "#/$defs/ContextBindings",
          "default": {
            "bindings": [],
            "disable_default": false
          }
        },
        "key_sequence_timeout_ms": {
          "description": "Timeout in milliseconds for multi-key sequences (default: 500).",
          "type": "integer",
          "format": "uint64",
          "default": 500,
          "minimum": 0
        },
        "universal": {
          "description": "Bindings active regardless of context.",
          "$ref": "#/$defs/ContextBindings",
          "default": {
            "bindings": [],
            "disable_default": false
          }
        }
      }
    },
    "MenuDefinition": {
      "description": "A user-defined menu definition.",
      "type": "object",
      "properties": {
        "items": {
          "description": "Menu items.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/MenuItemDef"
          }
        },
        "title": {
          "description": "Display title for the menu.",
          "type": "string"
        }
      },
      "required": [
        "title"
      ]
    },
    "MenuItemDef": {
      "description": "A single item in a user-defined menu.",
      "type": "object",
      "properties": {
        "action": {
          "description": "Built-in action name.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "background": {
          "description": "Run the shell command in the background without suspending the TUI.",
          "type": "boolean",
          "default": false
        },
        "key": {
          "description": "Shortcut key character.",
          "type": "string"
        },
        "label": {
          "description": "Display label.",
          "type": "string"
        },
        "notify": {
          "description": "IPC notification method name.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "run": {
          "description": "Shell command to execute (template string).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "required": [
        "key",
        "label"
      ]
    },
    "ModifiedAtColumnOptions": {
      "description": "Per-column options for the `ModifiedAt` column.",
      "type": "object",
      "properties": {
        "format": {
          "description": "Display format.",
          "$ref": "#/$defs/MtimeFormat",
          "default": "relative"
        },
        "mode": {
          "description": "How directory mtime is computed.",
          "$ref": "#/$defs/MtimeMode",
          "default": "os_mtime"
        }
      }
    },
    "MouseConfig": {
      "description": "Mouse input configuration.",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Whether mouse support (click, scroll wheel) is enabled.",
          "type": "boolean",
          "default": true
        }
      }
    },
    "MtimeFormat": {
      "description": "Display format for the `ModifiedAt` column.",
      "oneOf": [
        {
          "description": "Tiered relative time: `Xm ago`, `Xh ago`, `Xd ago`, `Xw ago`, then ISO.",
          "type": "string",
          "const": "relative"
        },
        {
          "description": "Always ISO format (`YYYY-MM-DD`).",
          "type": "string",
          "const": "absolute"
        }
      ]
    },
    "MtimeMode": {
      "description": "How directory modification times are computed.",
      "oneOf": [
        {
          "description": "Use the OS modification time of the directory itself.",
          "type": "string",
          "const": "os_mtime"
        },
        {
          "description": "Use the maximum mtime among all loaded descendant files (GitHub-like).",
          "type": "string",
          "const": "recursive_max"
        }
      ]
    },
    "PreviewConfig": {
      "description": "Preview configuration.",
      "type": "object",
      "properties": {
        "cache_size": {
          "description": "LRU cache capacity (default: 10).",
          "type": "integer",
          "format": "uint",
          "default": 50,
          "minimum": 0
        },
        "command_timeout": {
          "description": "Timeout for external commands in seconds (default: 3).",
          "type": "integer",
          "format": "uint64",
          "default": 3,
          "minimum": 0
        },
        "commands": {
          "description": "External preview commands.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/ExternalCommand"
          }
        },
        "max_bytes": {
          "description": "Maximum bytes to read per file (default: 10 MB).",
          "type": "integer",
          "format": "uint64",
          "default": 10485760,
          "minimum": 0
        },
        "max_lines": {
          "description": "Maximum number of lines to preview (default: 1000).",
          "type": "integer",
          "format": "uint",
          "default": 1000,
          "minimum": 0
        },
        "narrow_split_ratio": {
          "description": "Tree/preview split percentage in narrow layout (default: 60).",
          "type": "integer",
          "format": "uint16",
          "default": 60,
          "maximum": 65535,
          "minimum": 0
        },
        "narrow_width": {
          "description": "Width threshold for narrow layout in columns (default: 80).",
          "type": "integer",
          "format": "uint16",
          "default": 80,
          "maximum": 65535,
          "minimum": 0
        },
        "split_ratio": {
          "description": "Tree/preview split percentage in wide layout (default: 50).",
          "type": "integer",
          "format": "uint16",
          "default": 50,
          "maximum": 65535,
          "minimum": 0
        },
        "word_wrap": {
          "description": "Enable word wrap in preview (default: false).",
          "type": "boolean",
          "default": false
        }
      }
    },
    "Priority": {
      "description": "Priority for ordering (lower = higher priority). Number or named constant: high (0), mid (100), low (1000)",
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "string",
          "enum": [
            "high",
            "mid",
            "low"
          ]
        }
      ],
      "default": 100
    },
    "SearchConfig": {
      "description": "Search configuration.",
      "type": "object"
    },
    "SessionConfig": {
      "description": "Session persistence configuration.",
      "type": "object",
      "properties": {
        "expiry_days": {
          "description": "Days before a session file expires and is auto-deleted.",
          "type": "integer",
          "format": "uint64",
          "default": 90,
          "minimum": 0
        },
        "restore_by_default": {
          "description": "Whether to restore session by default on startup.",
          "type": "boolean",
          "default": true
        }
      }
    },
    "SortConfig": {
      "description": "Sort configuration.",
      "type": "object",
      "properties": {
        "direction": {
          "description": "Sort direction.",
          "$ref": "#/$defs/SortDirection",
          "default": "asc"
        },
        "directories_first": {
          "description": "Whether directories come first.",
          "type": "boolean",
          "default": true
        },
        "order": {
          "description": "Sort order field.",
          "$ref": "#/$defs/SortOrder",
          "default": "smart"
        }
      }
    },
    "SortDirection": {
      "description": "Sort direction.",
      "oneOf": [
        {
          "description": "Ascending order.",
          "type": "string",
          "const": "asc"
        },
        {
          "description": "Descending order.",
          "type": "string",
          "const": "desc"
        }
      ]
    },
    "SortOrder": {
      "description": "Sort order variants.",
      "oneOf": [
        {
          "description": "Natural sort with suffix grouping (test files after their base).",
          "type": "string",
          "const": "smart"
        },
        {
          "description": "Sort by name.",
          "type": "string",
          "const": "name"
        },
        {
          "description": "Sort by file size.",
          "type": "string",
          "const": "size"
        },
        {
          "description": "Sort by modification time.",
          "type": "string",
          "const": "mtime"
        },
        {
          "description": "Sort by file type.",
          "type": "string",
          "const": "type"
        },
        {
          "description": "Sort by file extension.",
          "type": "string",
          "const": "extension"
        }
      ]
    },
    "StyleConfig": {
      "description": "Display style configuration for file names.\n\nAll fields are optional/defaulted so partial overrides work naturally in YAML.",
      "type": "object",
      "properties": {
        "bg": {
          "description": "Background color (named color or hex string like `\"#D32F2F\"`).",
          "anyOf": [
            {
              "$ref": "#/$defs/ColorConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "bold": {
          "description": "Bold text modifier.",
          "type": "boolean",
          "default": false
        },
        "crossed_out": {
          "description": "Strikethrough text modifier.",
          "type": "boolean",
          "default": false
        },
        "dim": {
          "description": "Dim (reduced brightness) text modifier.",
          "type": "boolean",
          "default": false
        },
        "fg": {
          "description": "Foreground color (named color or hex string like `\"#D32F2F\"`).",
          "anyOf": [
            {
              "$ref": "#/$defs/ColorConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "italic": {
          "description": "Italic text modifier.",
          "type": "boolean",
          "default": false
        },
        "underlined": {
          "description": "Underlined text modifier.",
          "type": "boolean",
          "default": false
        }
      }
    },
    "WatcherConfig": {
      "description": "File system watcher configuration.",
      "type": "object",
      "properties": {
        "debounce_ms": {
          "description": "Debounce interval in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "default": 250,
          "minimum": 0
        },
        "enabled": {
          "description": "Whether FS watching is enabled.",
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
